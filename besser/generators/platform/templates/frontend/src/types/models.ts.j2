// ---------------------------------------------------------------------------
// Customization style types (visual overrides applied at runtime)
// ---------------------------------------------------------------------------

export type NodeShape = 'rectangle' | 'rounded_rect' | 'ellipse' | 'diamond' | 'hexagon';
export type LineStyleName = 'solid' | 'dashed' | 'dotted';
export type ArrowStyleName =
  | 'none'
  | 'filled_triangle'
  | 'open_triangle'
  | 'diamond'
  | 'open_diamond'
  | 'circle';
export type FontWeightName = 'normal' | 'bold';
export type LabelPositionName = 'top' | 'bottom' | 'inside';
export type ThemeName = 'light' | 'dark' | 'auto';
export type PortSideName = 'auto' | 'top' | 'right' | 'bottom' | 'left';
/** xyflow edge routing style. ``bezier`` = curved (default), ``smoothstep`` =
 *  rounded right-angles, ``step`` = sharp right-angles, ``straight`` =
 *  point-to-point line. */
export type LineRoutingName = 'bezier' | 'smoothstep' | 'step' | 'straight';

export interface NodeStyle {
  shape?: NodeShape;
  fillColor?: string;
  borderColor?: string;
  borderWidth?: number;
  borderStyle?: LineStyleName;
  borderRadius?: number;
  fontSize?: number;
  fontWeight?: FontWeightName;
  fontColor?: string;
  labelPosition?: LabelPositionName;
}

export interface EdgeStyle {
  color?: string;
  lineWidth?: number;
  lineStyle?: LineStyleName;
  /** Per-edge routing override; falls back to the diagram default. */
  lineRouting?: LineRoutingName;
  sourceArrow?: ArrowStyleName;
  targetArrow?: ArrowStyleName;
  labelVisible?: boolean;
  labelFontSize?: number;
  labelFontColor?: string;
}

export interface DiagramStyle {
  backgroundColor?: string;
  gridVisible?: boolean;
  gridSize?: number;
  snapToGrid?: boolean;
  theme?: ThemeName;
  /** Default edge routing. ``bezier`` when omitted. */
  lineRouting?: LineRoutingName;
}

// Class metadata
export interface ClassMetadata {
  name: string;
  icon?: string; // SVG icon as plain text
  /** True when the class is declared abstract — never instantiated directly. */
  isAbstract?: boolean;
  isContainer?: boolean; // container classes render as drop-zone rectangles
  isResizable?: boolean; // shows xyflow NodeResizer handles when selected
  /** Renders as a graphical Handle on its owning equipment node, not a node. */
  isPort?: boolean;
  /** Renders as an edge between two ports, not a node. */
  isConnectionClass?: boolean;
  /** Side on the owning node where a port-class instance anchors. */
  portSide?: PortSideName;
  /** Sides on which the default xyflow handles render. ``undefined`` keeps
   *  the four-side default; an explicit list restricts; ``[]`` hides them. */
  connectionPoints?: Array<'top' | 'right' | 'bottom' | 'left'>;
  defaultSize?: { width: number; height: number };
  attributes: AttributeMetadata[];
  associations: AssociationMetadata[];
  style?: NodeStyle; // Per-class appearance overrides
  /** Edge style — only meaningful for connection classes; applied by the
   *  runtime to the synthetic edge drawn between two ports. */
  edgeStyle?: EdgeStyle;
}

export interface AttributeMetadata {
  name: string;
  type: string;
  required: boolean;
}

export interface AssociationMetadata {
  name: string;
  targetClass: string;
  sourceEndName: string; // End name on source side
  targetEndName: string; // End name on target side
  multiplicity: {
    min: number;
    max: number;
  };
  edgeColor?: string; // CSS color (hex, hsl, etc.); omitted uses the theme default
  style?: EdgeStyle; // Per-association edge overrides
  /**
   * Marks this association as the containment relationship: when the source
   * class is a container, dropping a target instance inside one of its
   * instances auto-creates this link and visually nests the child node.
   */
  isContainerAssociation?: boolean;
  /** Marks this association as the source-port endpoint of a connection-class. */
  isSourceEndpoint?: boolean;
  /** Marks this association as the target-port endpoint of a connection-class. */
  isTargetEndpoint?: boolean;
}

// Port class metadata: instances of a port-class render as Handles on their
// owning equipment node instead of as standalone nodes.
export interface PortClassMeta {
  /** Where the handle anchors on the owning equipment ('auto' falls back to
   *  the port instance's `direction` attribute). */
  portSide: PortSideName;
}

// Connection class metadata: instances of a connection-class render as edges
// between two ports rather than as nodes. The two endpoint associations are
// resolved at generation time from the platform customization.
export interface ConnectionClassMeta {
  /** Name of the association whose target end is the source port of the edge. */
  sourceAssociation: string | null;
  /** Name of the association whose target end is the target port of the edge. */
  targetAssociation: string | null;
  /** Class name of the port-class on either endpoint (both should match). */
  portClass: string | null;
}

