# BESSER Backend Configuration (.env.example)
# This is the BACKEND-ONLY environment file.
# 
# Frontend configuration is in: besser/utilities/web_modeling_editor/frontend/packages/webapp/webpack/.env.example

# === GMAIL Configuration (Backend Only) ===
FEEDBACK_EMAIL=your-email@example.com,team@example.com
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# === GitHub OAuth (Backend Only) ===
# Create OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_REDIRECT_URI=https://editor.besser-pearl.org/besser_api/github/auth/callback
GITHUB_REDIRECT_URI_LOCAL=http://localhost:9000/besser_api/github/auth/callback

# === OpenAI (Backend Only) ===
# Used by image-to-model, knowledge graph, and agent personalization features
OPENAI_API_KEY=your_openai_key_here

# === Free tier (Backend Only) ===
# Keyless "Free" option for the Spec-Driven Agent, backed by a self-hosted
# open-weight model behind an OpenAI-compatible endpoint (e.g. Ollama). When
# BASE_URL and MODEL are both set, the backend advertises the free tier in
# GET /besser_api/smart-gen/config and injects these server-side — the URL,
# token, and model NEVER travel to the browser. Leave unset to disable.
# SECURITY: TOKEN is a secret (bearer credential to a shared GPU) — set it in
# the real .env on the server only, never commit a value here.
BESSER_FREE_LLM_BASE_URL=
BESSER_FREE_LLM_TOKEN=
BESSER_FREE_LLM_MODEL=
