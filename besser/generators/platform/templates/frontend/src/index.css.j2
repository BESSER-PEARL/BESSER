@import url('https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&display=swap');

@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    --background: 48 30% 97%;
    --foreground: 220 25% 10%;

    --card: 0 0% 100%;
    --card-foreground: 220 25% 10%;

    --popover: 0 0% 100%;
    --popover-foreground: 220 25% 10%;

    --primary: 192 80% 20%;
    --primary-foreground: 0 0% 100%;

    --secondary: 160 18% 92%;
    --secondary-foreground: 220 28% 14%;

    --muted: 210 22% 94%;
    --muted-foreground: 215 12% 44%;

    --accent: 196 42% 93%;
    --accent-foreground: 192 80% 20%;

    --destructive: 4 76% 50%;
    --destructive-foreground: 0 0% 100%;

    --success: 142 76% 35%;
    --success-foreground: 0 0% 100%;

    --warning: 25 95% 53%;
    --warning-foreground: 0 0% 100%;

    --border: 210 18% 86%;
    --input: 210 18% 86%;
    --ring: 192 80% 42%;

    --radius: 0.5rem;
  }

  .dark {
    --background: 222 22% 8%;
    --foreground: 210 18% 92%;

    --card: 222 22% 12%;
    --card-foreground: 210 18% 92%;

    --popover: 222 22% 12%;
    --popover-foreground: 210 18% 92%;

    --primary: 192 75% 58%;
    --primary-foreground: 222 22% 8%;

    --secondary: 222 18% 16%;
    --secondary-foreground: 210 18% 92%;

    --muted: 222 18% 14%;
    --muted-foreground: 215 14% 62%;

    --accent: 222 18% 16%;
    --accent-foreground: 210 18% 92%;

    --destructive: 4 76% 56%;
    --destructive-foreground: 0 0% 100%;

    --success: 142 70% 45%;
    --success-foreground: 0 0% 100%;

    --warning: 25 90% 56%;
    --warning-foreground: 0 0% 100%;

    --border: 222 18% 22%;
    --input: 222 18% 22%;
    --ring: 192 75% 58%;
  }
}

@layer base {
  * {
    @apply border-border;
  }
  html,
  body,
  #root {
    height: 100%;
  }
  body {
    @apply bg-background text-foreground antialiased font-sans;
  }
}

/* Subtle scrollbars */
@layer utilities {
  .scrollbar-thin::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background: hsl(var(--border));
    border-radius: 4px;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb:hover {
    background: hsl(var(--muted-foreground));
  }
}
