/**
 * ClassPalette Component
 * Sidebar with draggable class cards for creating new instances.
 */
{% raw %}
import React from 'react';
import { GripVertical } from 'lucide-react';
import { Card } from '@/components/ui/card';
import type { ClassMetadata } from '../types/models';

interface ClassPaletteProps {
  classes: ClassMetadata[];
  onInstanceCreated: () => void;
}

export const ClassPalette: React.FC<ClassPaletteProps> = ({ classes }) => {
  const handleDragStart = (e: React.DragEvent, classMetadata: ClassMetadata) => {
    e.dataTransfer.setData('className', classMetadata.name);
    e.dataTransfer.effectAllowed = 'copy';
  };

  return (
    <aside className="flex w-72 flex-col overflow-hidden border-r bg-card">
      <div className="border-b bg-background/60 px-5 py-4">
        <h3 className="mb-1 font-sans text-base font-bold text-foreground">Classes</h3>
        <p className="text-xs leading-snug text-muted-foreground">
          Drag a class onto the canvas to create an instance.
        </p>
      </div>

      <div className="scrollbar-thin flex flex-1 flex-col gap-2 overflow-y-auto p-3">
        {classes.map((classMetadata) => (
          <Card
            key={classMetadata.name}
            draggable
            onDragStart={(e) => handleDragStart(e, classMetadata)}
            className="group flex cursor-grab select-none items-center gap-3 border-2 border-border p-3 transition-all hover:-translate-y-0.5 hover:border-primary hover:shadow-md active:cursor-grabbing active:translate-y-0"
          >
            <div className="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-md bg-primary/10 text-primary">
              {classMetadata.icon ? (
                <div
                  className="flex h-full w-full items-center justify-center [&_svg]:h-7 [&_svg]:w-7"
                  dangerouslySetInnerHTML={{ __html: classMetadata.icon }}
                />
              ) : (
                <span className="text-lg font-bold">
                  {classMetadata.name.charAt(0).toUpperCase()}
                </span>
              )}
            </div>
            <div className="min-w-0 flex-1">
              <div className="truncate text-sm font-semibold text-foreground">
                {classMetadata.name}
              </div>
              <div className="text-xs text-muted-foreground">
                {classMetadata.attributes.length} attribute
                {classMetadata.attributes.length === 1 ? '' : 's'}
              </div>
            </div>
            <GripVertical className="h-4 w-4 flex-shrink-0 text-muted-foreground opacity-0 transition-opacity group-hover:opacity-100" />
          </Card>
        ))}
      </div>
    </aside>
  );
};
{% endraw %}
