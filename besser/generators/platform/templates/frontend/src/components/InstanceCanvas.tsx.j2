  <svg style={{ position: 'absolute', width: 0, height: 0 }} aria-hidden>
    <defs>
      <marker
        id="platform-diamond"
        viewBox="0 0 12 12"
        refX="11"
        refY="6"
        markerWidth="12"
        markerHeight="12"
