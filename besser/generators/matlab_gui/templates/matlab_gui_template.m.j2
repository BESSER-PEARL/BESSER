{%- set ec       = '{}' -%}
{%- set fit      = "{'fit'}" -%}
{%- set onex     = "{'1x'}" -%}
{%- set form_col = "{'fit','1x'}" -%}
{%- set tall_row = "{300}" -%}
%% {{ app_name }}App.m
%% Auto-generated by BESSER MatlabGuiGenerator
%% Domain : {{ model.name }}
%% Pages  : {{ pages | length }}
%% Run in MATLAB R2020b or later.

function {{ app_name }}App()

    %% ── Colours ──────────────────────────────────────────────────────
    C.navy  = [0.161, 0.149, 0.506];
    C.blue  = [0.000, 0.447, 0.741];
    C.green = [0.180, 0.620, 0.345];
    C.red   = [0.827, 0.212, 0.212];
    C.bg    = [0.949, 0.949, 0.953];
    C.white = [1.000, 1.000, 1.000];
    C.grey  = [0.450, 0.450, 0.450];
    C.dark  = [0.180, 0.180, 0.250];

    %% ── Figure ───────────────────────────────────────────────────────
    fig = uifigure( ...
        'Name',     '{{ app_name }}', ...
        'Position', [60, 60, 1280, 800], ...
        'Color',    C.bg);

{% if pages | length == 0 %}
    uilabel(fig, ...
        'Text',     'No pages defined.', ...
        'Position', [40, 380, 600, 30], ...
        'FontSize', 14, 'FontColor', C.grey);

{% else %}

{% if pages | length > 1 %}
    %% Tab group fills entire figure (no gap at top)
    tg = uitabgroup(fig, ...
        'Units',    'normalized', ...
        'Position', [0, 0, 1, 1]);
{% endif %}

{% for page in pages %}
{%- set pid             = loop.index %}
{%- set all_widgets     = flatten(page.components or []) %}
{%- set nav_widgets     = all_widgets | selectattr('type', 'in', ['menu','link','link-button']) | list %}
{%- set content_widgets = all_widgets | rejectattr('type', 'in', ['menu','link','link-button']) | list %}
{%- set has_nav         = nav_widgets | length > 0 %}

{%- if pages | length > 1 %}
    tab_{{ pid }} = uitab(tg, 'Title', '{{ (page.name or ("Page " ~ pid)) | replace("'","''") }}');
{%- set tab_parent = 'tab_' ~ pid %}
{%- else %}
{%- set tab_parent = 'fig' %}
{%- endif %}

{%- set nav_items = [] %}
{%- for w in nav_widgets %}
{%- if w.type == 'menu' %}
{%- for item in (w.items or []) %}
{%- set _ = nav_items.append(item.label or '') %}
{%- endfor %}
{%- else %}
{%- set _ = nav_items.append(w.label or w.name or '') %}
{%- endif %}
{%- endfor %}
{%- set n_nav = nav_items | length %}

{% if has_nav %}
    root_{{ pid }} = uigridlayout({{ tab_parent }}, ...
        'ColumnWidth',   {200,'1x'}, ...
        'RowHeight',     {'1x'}, ...
        'Padding',       [0 0 0 0], ...
        'ColumnSpacing', 0, ...
        'BackgroundColor', C.bg);

    %% ── Sidebar ──────────────────────────────────────────────────────
    pnl_side_{{ pid }} = uipanel(root_{{ pid }}, ...
        'BackgroundColor', C.navy, ...
        'BorderType',      'none');


{%- set side_rows = [34] + ([28] * n_nav) %}
    gl_side_{{ pid }} = uigridlayout(pnl_side_{{ pid }}, ...
        'ColumnWidth', {{ onex }}, ...
        'RowHeight',   { {{ side_rows | join(', ') }}, '1x'}, ...
        'Padding',     [8 16 8 8], ...
        'RowSpacing',  2, ...
        'BackgroundColor', C.navy);

    uilabel(gl_side_{{ pid }}, ...
        'Text',      'BESSER', ...
        'FontSize',  15, ...
        'FontWeight','bold', ...
        'FontColor', C.white, ...
        'BackgroundColor', C.navy);

{% for label in nav_items %}
{%- set nid = 'nav_' ~ safe_id(label) ~ '_' ~ pid %}
    btn_{{ nid }} = uibutton(gl_side_{{ pid }}, ...
        'Text',            '{{ label | replace("'","''") }}', ...
        'BackgroundColor', C.navy, ...
        'FontColor',       C.white, ...
        'FontSize',        12, ...
        'HorizontalAlignment', 'left', ...
        'ButtonPushedFcn', @(~,~) disp('{{ label | replace("'","''") }}'));
{% endfor %}
    uilabel(gl_side_{{ pid }}, 'Text', '', 'BackgroundColor', C.navy);

    %% ── Content panel ────────────────────────────────────────────────
    pnl_cnt_{{ pid }} = uipanel(root_{{ pid }}, ...
        'BackgroundColor', C.bg, ...
        'BorderType',      'none');
    gl_{{ pid }} = uigridlayout(pnl_cnt_{{ pid }}, ...
        'ColumnWidth', {{ onex }}, ...
        'RowHeight',   {{ fit }}, ...
        'Padding',     [20 20 20 20], ...
        'RowSpacing',  4, ...
        'BackgroundColor', C.bg);

{% else %}
    gl_{{ pid }} = uigridlayout({{ tab_parent }}, ...
        'ColumnWidth', {{ onex }}, ...
        'RowHeight',   {{ fit }}, ...
        'Padding',     [20 20 20 20], ...
        'RowSpacing',  4, ...
        'BackgroundColor', C.bg);
{% endif %}

    %% ── Widgets for {{ page.name }} ──────────────────────────────────
{% for comp in content_widgets %}
{%- set cid      = 'w_' ~ safe_id(comp.id or comp.name or 'comp') ~ '_' ~ pid ~ '_' ~ loop.index %}
{%- set ctype    = (comp.type or 'component') | lower %}
{%- set gl       = 'gl_' ~ pid %}
{%- set txt_c    = (comp.content or comp.name or '') %}
{%- set txt_low  = txt_c | lower %}
{%- set skip     = (ctype == 'text') and (
        txt_low == 'besser'
        or 'rights reserved' in txt_low
        or 'copyright'       in txt_low
        or txt_low.startswith('manage ')
        or txt_low == 'data preview only'
        or txt_low == 'data preview only.'
    ) %}

{% if skip %}
{# filtered out #}

{% elif ctype == 'text' %}
{%- set txt = txt_c | replace("'","''") %}
{% if comp.tag and comp.tag | lower in ['h1','h2','h3','h4'] %}
    uilabel({{ gl }}, ...
        'Text',       '{{ txt }}', ...
        'FontSize',   {% if comp.tag|lower=='h1' %}22{% elif comp.tag|lower=='h2' %}17{% elif comp.tag|lower=='h3' %}14{% else %}12{% endif %}, ...
        'FontWeight', 'bold', ...
        'FontColor',  [0.1 0.1 0.1]);
{% else %}
    uilabel({{ gl }}, ...
        'Text',      '{{ txt }}', ...
        'FontSize',  11, ...
        'FontColor', C.grey);
{% endif %}

{% elif ctype in ['button','action-button'] %}
{%- set lbl       = (comp.label or comp.name or 'Button') | replace("'","''") %}
{%- set lbl_lower = (comp.label or comp.name or '') | lower %}
{%- set is_del    = 'delete' in lbl_lower or 'remove' in lbl_lower %}
{%- set is_add    = 'add' in lbl_lower or 'new' in lbl_lower or 'create' in lbl_lower %}
    gl_btn_{{ cid }} = uigridlayout({{ gl }}, ...
        'ColumnWidth', {'fit','1x'}, ...
        'RowHeight',   {30}, ...
        'Padding',     [0 0 0 0], ...
        'BackgroundColor', C.bg);
    btn_{{ cid }} = uibutton(gl_btn_{{ cid }}, ...
        'Text',            '{{ lbl }}', ...
        'BackgroundColor', {% if is_del %}C.red{% elif is_add %}C.green{% else %}C.blue{% endif %}, ...
        'FontColor',       C.white, ...
        'FontSize',        11, ...
        'ButtonPushedFcn', @(~,~) cb_{{ cid }}());
    uilabel(gl_btn_{{ cid }}, 'Text', '', 'BackgroundColor', C.bg);

{% elif ctype == 'table' %}
{%- set cols    = comp.chart.columns if comp.chart and comp.chart.columns else [] %}
{%- set add_lbl = ('+ Add ' ~ ((comp.title or comp.name or 'Item') | replace('List','') | replace('list','') | trim)) | replace("'","''") %}
{%- set tbl_lbl = (comp.title or comp.name or 'Table') | replace("'","''") %}

    pnl_tbl_{{ cid }} = uipanel({{ gl }}, ...
        'Title',           '{{ tbl_lbl }}', ...
        'FontWeight',      'bold', ...
        'FontSize',        12, ...
        'BackgroundColor', C.white);
    gl_tbl_{{ cid }} = uigridlayout(pnl_tbl_{{ cid }}, ...
        'ColumnWidth', {{ onex }}, ...
        'RowHeight',   {28, 220}, ...
        'Padding',     [8 8 8 8], ...
        'RowSpacing',  4);

    gl_tb_{{ cid }} = uigridlayout(gl_tbl_{{ cid }}, ...
        'ColumnWidth', {'1x','fit'}, ...
        'RowHeight',   {'fit'}, ...
        'Padding',     [0 0 0 0], ...
        'BackgroundColor', C.white);
    uilabel(gl_tb_{{ cid }}, ...
        'Text',      'Data preview only.', ...
        'FontSize',  10, ...
        'FontColor', C.grey, ...
        'BackgroundColor', C.white);
    btn_add_{{ cid }} = uibutton(gl_tb_{{ cid }}, ...
        'Text',            '{{ add_lbl }}', ...
        'BackgroundColor', C.blue, ...
        'FontColor',       C.white, ...
        'FontSize',        11, ...
        'ButtonPushedFcn', @(~,~) cb_add_{{ cid }}());

    tbl_{{ cid }} = uitable(gl_tbl_{{ cid }}, ...
        'RowStriping', 'on', ...
{% if cols %}
        'ColumnName',  { {% for col in cols %}'{{ col.label | replace("'","''") }}'{% if not loop.last %}, {% endif %}{% endfor %} }, ...
        'Data',        { {% for r in range(1,6) %}{% for col in cols %}'{{ col.label | replace("'","''") }} {{ r }}'{% if not loop.last %}, {% endif %}{% endfor %}{% if not loop.last %}; {% endif %}{% endfor %} });
{% else %}
        'ColumnName',  {'Column 1','Column 2','Column 3'}, ...
        'Data',        {'Row 1 A','Row 1 B','Row 1 C'; ...
                        'Row 2 A','Row 2 B','Row 2 C'; ...
                        'Row 3 A','Row 3 B','Row 3 C'});
{% endif %}

{% elif ctype == 'input' %}
{%- set itype = (comp.input_type or 'text') | lower %}
    uilabel({{ gl }}, 'Text', '{{ (comp.name or 'Input') | replace("'","''") }}:', 'FontSize', 11);
{% if itype in ['number','integer','float','numeric'] %}
    ef_{{ cid }} = uieditfield({{ gl }}, 'numeric');
{% else %}
    ef_{{ cid }} = uieditfield({{ gl }}, 'text', ...
        'Placeholder', '{{ (comp.name or '') | replace("'","''") }}');
{% endif %}

{% elif ctype == 'form' %}
    pnl_{{ cid }} = uipanel({{ gl }}, ...
        'Title',           '{{ (comp.name or 'Form') | replace("'","''") }}', ...
        'FontWeight',      'bold', ...
        'BackgroundColor', C.white);
    gl_f_{{ cid }} = uigridlayout(pnl_{{ cid }}, ...
        'ColumnWidth', {{ form_col }}, ...
        'RowHeight',   {{ fit }}, ...
        'Padding',     [12 12 12 12], ...
        'RowSpacing',  8);
{% for field in (comp.inputs or []) %}
{%- set ftype = (field.type or 'text') | lower %}
    uilabel(gl_f_{{ cid }}, 'Text', '{{ (field.label or field.id or 'Field') | replace("'","''") }}:', 'FontSize', 11);
{% if ftype in ['number','integer','float','numeric'] %}
    uieditfield(gl_f_{{ cid }}, 'numeric');
{% else %}
    uieditfield(gl_f_{{ cid }}, 'text');
{% endif %}
{% endfor %}
    uibutton(gl_f_{{ cid }}, 'Text', 'Submit', ...
        'BackgroundColor', C.blue, 'FontColor', C.white);

{% elif ctype == 'data-list' %}
    lst_{{ cid }} = uilistbox({{ gl }}, 'Items', {{ ec }});

{% elif ctype == 'image' %}
    uiimage({{ gl }}, 'ImageSource', '{{ (comp.src or '') | replace("'","''") }}');

{% elif ctype in ['bar-chart','line-chart','pie-chart','radar-chart','radial-bar-chart'] %}
    pnl_ch_{{ cid }} = uipanel({{ gl }}, ...
        'Title',           '{{ (comp.title or comp.name or ctype) | replace("'","''") }}', ...
        'FontWeight',      'bold', ...
        'BackgroundColor', C.white);
    gl_ch_{{ cid }} = uigridlayout(pnl_ch_{{ cid }}, ...
        'ColumnWidth', {{ onex }}, 'RowHeight', {{ tall_row }}, 'Padding', [8 8 8 8]);
    ax_{{ cid }} = uiaxes(gl_ch_{{ cid }});
    ax_{{ cid }}.Title.String = '{{ (comp.title or comp.name or '') | replace("'","''") }}';
    ax_{{ cid }}.Color  = C.white;
    ax_{{ cid }}.XColor = [0.2 0.2 0.2];
    ax_{{ cid }}.YColor = [0.2 0.2 0.2];
{% if ctype == 'bar-chart' %}
    bar(ax_{{ cid }}, categorical({'Jan','Feb','Mar','Apr','May','Jun'}), ...
        [42 58 35 71 49 63], 'FaceColor', C.blue);
    grid(ax_{{ cid }}, 'on');
{% elif ctype == 'line-chart' %}
    plot(ax_{{ cid }}, 1:6, [28 45 38 62 51 74], '-o', ...
        'LineWidth', 2.5, 'Color', C.blue, 'MarkerFaceColor', C.blue);
    set(ax_{{ cid }}, 'XTick', 1:6, 'XTickLabel', {'Jan','Feb','Mar','Apr','May','Jun'});
    grid(ax_{{ cid }}, 'on');
{% elif ctype == 'pie-chart' %}
    pie(ax_{{ cid }}, [35 25 20 12 8], {'A','B','C','D','E'});
{% elif ctype == 'radar-chart' %}
    polarplot(ax_{{ cid }}, linspace(0,2*pi,7), [4 7 3 8 5 6 4], ...
        '-o', 'LineWidth', 2.5, 'Color', C.blue);
{% else %}
    polarplot(ax_{{ cid }}, linspace(0,2*pi,100), ...
        abs(sin(2*linspace(0,2*pi,100))).*8, 'LineWidth', 2.5, 'Color', C.blue);
{% endif %}

{% elif ctype == 'metric-card' %}
    pnl_mc_{{ cid }} = uipanel({{ gl }}, ...
        'Title',           '{{ (comp.title or comp.name or 'Metric') | replace("'","''") }}', ...
        'FontWeight',      'bold', 'BackgroundColor', C.white);
    gl_mc_{{ cid }} = uigridlayout(pnl_mc_{{ cid }}, ...
        'ColumnWidth', {{ onex }}, 'RowHeight', {{ fit }}, 'Padding', [16 16 16 16]);
    uilabel(gl_mc_{{ cid }}, 'Text', '1,284', ...
        'FontSize', 32, 'FontWeight', 'bold', ...
        'HorizontalAlignment', 'center', 'FontColor', C.navy);

{% elif ctype == 'agent-component' %}
{%- set agent_title = comp.get('agent-title', comp.name or 'BESSER Agent') %}
    pnl_ag_{{ cid }} = uipanel({{ gl }}, ...
        'Title', '{{ agent_title | replace("'","''") }}', ...
        'FontWeight', 'bold', 'BackgroundColor', C.white);
    gl_ag_{{ cid }} = uigridlayout(pnl_ag_{{ cid }}, ...
        'ColumnWidth', {{ onex }}, 'RowHeight', {'1x','fit'}, ...
        'Padding', [8 8 8 8], 'RowSpacing', 6);
    uitextarea(gl_ag_{{ cid }}, ...
        'Value', {'[Agent] Hello! How can I help you today?'}, 'Editable', 'off');
    uieditfield(gl_ag_{{ cid }}, 'text', 'Placeholder', 'Type a message...');

{% else %}
    uilabel({{ gl }}, 'Text', '[{{ ctype }}]', 'FontColor', C.grey, 'FontSize', 10);
{% endif %}

{% endfor %}
{% endfor %}
{% endif %}

    %% ── Status bar ───────────────────────────────────────────────────
    uilabel(fig, ...
        'Text',            '  {{ app_name }} — BESSER Generated GUI', ...
        'Position',        [0, 0, 1280, 24], ...
        'BackgroundColor', C.dark, ...
        'FontColor',       [0.65, 0.90, 0.65], ...
        'FontName',        'Courier New', ...
        'FontSize',        9);

end %% {{ app_name }}App


%% ═══════════════════════════════════════════════════════════════════════
%%  Callbacks
%% ═══════════════════════════════════════════════════════════════════════
{% for page in pages %}
{%- set pid             = loop.index %}
{%- set all_widgets     = flatten(page.components or []) %}
{%- set content_widgets = all_widgets | rejectattr('type', 'in', ['menu','link','link-button']) | list %}
{% for comp in content_widgets %}
{%- set ctype = (comp.type or '') | lower %}
{%- set cid   = 'w_' ~ safe_id(comp.id or comp.name or 'comp') ~ '_' ~ pid ~ '_' ~ loop.index %}
{% if ctype in ['button','action-button'] %}

function cb_{{ cid }}()
    %% TODO: '{{ (comp.label or comp.name or 'Button') | replace("'","''") }}'
    disp('{{ (comp.label or comp.name or 'Button') | replace("'","''") }} pressed');
end
{% endif %}
{% if ctype == 'table' %}

function cb_add_{{ cid }}()
    %% TODO: Add row for '{{ (comp.title or comp.name or 'Table') | replace("'","''") }}'
    disp('Add {{ (comp.title or comp.name or 'item') | replace("'","''") }}');
end
{% endif %}
{% endfor %}
{% endfor %}