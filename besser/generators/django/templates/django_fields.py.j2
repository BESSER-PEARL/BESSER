{%- macro get_field(attr_type, enumerations, is_id=False) %}
    {%- if attr_type.name == "str" %} models.CharField(max_length=255{% if is_id %}, primary_key=True{% endif %})
    {%- elif attr_type.name == "int" %} models.IntegerField({% if is_id %}primary_key=True{% endif %})
    {%- elif attr_type.name == "float" %} models.FloatField({% if is_id %}primary_key=True{% endif %})
    {%- elif attr_type.name == "date" %} models.DateField({% if is_id %}primary_key=True{% endif %})
    {%- elif attr_type.name == "datetime" %} models.DateTimeField({% if is_id %}primary_key=True{% endif %})
    {%- elif attr_type.name == "bool" %} models.BooleanField({% if is_id %}primary_key=True{% endif %})
    {%- elif attr_type.name == "text" %} models.TextField({% if is_id %}primary_key=True{% endif %})
    {%- elif attr_type.name == "uuid" %} models.UUIDField({% if is_id %}primary_key=True{% endif %})
    {%- elif attr_type in enumerations %} models.CharField(max_length=255, choices={{attr_type.name}}.choices{% if is_id %}, primary_key=True{% endif %})
    {%- else %}
    {# Unknown field type #}
None
    {%- endif %}
{%- endmacro %}
