{%- macro _opts(is_id, is_external_id) -%}
{%- if is_id %}, primary_key=True{% endif %}
{%- if is_external_id and not is_id %}, unique=True{% endif %}
{%- endmacro -%}
{%- macro get_field(attr_type, enumerations, is_id=False, is_external_id=False) %}
    {%- set opts = _opts(is_id, is_external_id) %}
    {%- if attr_type.name == "str" %} models.CharField(max_length=255{{ opts }})
    {%- elif attr_type.name == "int" %} models.IntegerField({% if is_id %}primary_key=True{% elif is_external_id %}unique=True{% endif %})
    {%- elif attr_type.name == "float" %} models.FloatField({% if is_id %}primary_key=True{% elif is_external_id %}unique=True{% endif %})
    {%- elif attr_type.name == "date" %} models.DateField({% if is_id %}primary_key=True{% elif is_external_id %}unique=True{% endif %})
    {%- elif attr_type.name == "datetime" %} models.DateTimeField({% if is_id %}primary_key=True{% elif is_external_id %}unique=True{% endif %})
    {%- elif attr_type.name == "bool" %} models.BooleanField({% if is_id %}primary_key=True{% elif is_external_id %}unique=True{% endif %})
    {%- elif attr_type.name == "text" %} models.TextField({% if is_id %}primary_key=True{% elif is_external_id %}unique=True{% endif %})
    {%- elif attr_type.name == "uuid" %} models.UUIDField({% if is_id %}primary_key=True{% elif is_external_id %}unique=True{% endif %})
    {%- elif attr_type in enumerations %} models.CharField(max_length=255, choices={{attr_type.name}}.choices{{ opts }})
    {%- else %}
    {# Unknown field type #}
None
    {%- endif %}
{%- endmacro %}

