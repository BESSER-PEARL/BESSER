      >
        <polygon points="0,6 6,0 12,6 6,12" fill="currentColor" />
      </marker>
      <marker
        id="platform-open-diamond"
        viewBox="0 0 12 12"
        refX="11"
        refY="6"
        markerWidth="12"
        markerHeight="12"
        orient="auto-start-reverse"
      >
        <polygon
          points="0,6 6,0 12,6 6,12"
          fill="hsl(var(--card))"
