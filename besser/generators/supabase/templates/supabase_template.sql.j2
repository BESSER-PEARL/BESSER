-- =============================================================================
-- BESSER Supabase Generator
-- Model: {{ model.name }}
-- File:  {{ filename }}
-- =============================================================================
-- Apply this schema in one of two ways:
--
--   Cloud:  Open https://supabase.com/dashboard -> your project ->
--           SQL Editor -> New query -> paste this file -> Run.
--
--   Local:  Drop this file into supabase/migrations/ (its filename already
--           has the required <timestamp>_<name>.sql format), then run:
--               supabase db reset
--           Requires Docker Desktop + the supabase CLI; run `supabase init`
--           once in your project root first.
--
-- Push the local-tested schema to a cloud project with `supabase db push`
-- after `supabase link --project-ref <your-project-ref>`.
-- =============================================================================
-- Note: pgcrypto (for gen_random_uuid()) is pre-enabled on every Supabase
-- project. If targeting a non-Supabase Postgres, uncomment the line below:
-- CREATE EXTENSION IF NOT EXISTS pgcrypto;

{% set non_empty_enums = model.get_enumerations() | selectattr("literals") | list %}
{% if non_empty_enums %}
-- =============================================================================
-- Enumerations
-- =============================================================================
{% for enum in non_empty_enums %}
DO $$ BEGIN
    CREATE TYPE "{{ enum.name | lower }}" AS ENUM (
{% for lit in enum.literals %}
        '{{ lit.name }}'{{ "," if not loop.last else "" }}
{% endfor %}
    );
EXCEPTION WHEN duplicate_object THEN NULL; END $$;

{% endfor %}
{% endif %}
-- =============================================================================
-- Tables
-- =============================================================================
{% for t in tables %}
CREATE TABLE IF NOT EXISTS public."{{ t.name }}" (
{% for col in t.columns %}
    {{ col }}{{ "," if not loop.last else "" }}
{% endfor %}
);

{% if t.is_per_user %}
CREATE INDEX IF NOT EXISTS "idx_{{ t.name }}_user_id" ON public."{{ t.name }}"("user_id");

{% endif %}
{% endfor %}
{% if user_root %}
-- =============================================================================
-- auth.users -> public.{{ user_root_tbl }} trigger
-- =============================================================================
CREATE OR REPLACE FUNCTION public.handle_new_user()
RETURNS TRIGGER
LANGUAGE plpgsql
SECURITY DEFINER
SET search_path = ''
AS $$
BEGIN
    INSERT INTO public."{{ user_root_tbl }}" (id)
    VALUES (NEW.id)
    ON CONFLICT (id) DO NOTHING;
    RETURN NEW;
END;
$$;

DROP TRIGGER IF EXISTS on_auth_user_created ON auth.users;
CREATE TRIGGER on_auth_user_created
    AFTER INSERT ON auth.users
    FOR EACH ROW EXECUTE FUNCTION public.handle_new_user();

{% endif %}
-- =============================================================================
-- Association foreign keys (added via ALTER so table order doesn't matter)
-- =============================================================================
{% for fk in fk_alters %}
ALTER TABLE public."{{ fk[0] }}"
    ADD COLUMN IF NOT EXISTS "{{ fk[1] }}" UUID{% if not fk[3] %} NOT NULL{% endif %} REFERENCES public."{{ fk[2] }}"(id) ON DELETE CASCADE;
CREATE INDEX IF NOT EXISTS "idx_{{ fk[0] }}_{{ fk[1] }}" ON public."{{ fk[0] }}"("{{ fk[1] }}");

{% endfor %}
-- =============================================================================
-- Grants (Supabase ships sensible default privileges; emitted explicitly for
-- portability to non-Supabase Postgres and to projects with reset defaults)
-- =============================================================================
GRANT USAGE ON SCHEMA public TO authenticated;
GRANT SELECT, INSERT, UPDATE, DELETE ON
{% for t in tables %}
    public."{{ t.name }}"{{ "," if not loop.last else "" }}
{% endfor %}
TO authenticated;

-- =============================================================================
-- Row Level Security
-- =============================================================================
{% if user_root %}
ALTER TABLE public."{{ user_root_tbl }}" ENABLE ROW LEVEL SECURITY;

DROP POLICY IF EXISTS "{{ user_root_tbl }}_select_own" ON public."{{ user_root_tbl }}";
CREATE POLICY "{{ user_root_tbl }}_select_own" ON public."{{ user_root_tbl }}"
    AS PERMISSIVE FOR SELECT
    TO authenticated
    USING ((SELECT auth.uid()) = id);

DROP POLICY IF EXISTS "{{ user_root_tbl }}_insert_own" ON public."{{ user_root_tbl }}";
CREATE POLICY "{{ user_root_tbl }}_insert_own" ON public."{{ user_root_tbl }}"
    AS PERMISSIVE FOR INSERT
    TO authenticated
    WITH CHECK ((SELECT auth.uid()) = id);

DROP POLICY IF EXISTS "{{ user_root_tbl }}_update_own" ON public."{{ user_root_tbl }}";
CREATE POLICY "{{ user_root_tbl }}_update_own" ON public."{{ user_root_tbl }}"
    AS PERMISSIVE FOR UPDATE
    TO authenticated
    USING ((SELECT auth.uid()) = id)
    WITH CHECK ((SELECT auth.uid()) = id);

DROP POLICY IF EXISTS "{{ user_root_tbl }}_delete_own" ON public."{{ user_root_tbl }}";
CREATE POLICY "{{ user_root_tbl }}_delete_own" ON public."{{ user_root_tbl }}"
    AS PERMISSIVE FOR DELETE
    TO authenticated
    USING ((SELECT auth.uid()) = id);

{% endif %}
{% for t in tables if t.is_per_user %}
ALTER TABLE public."{{ t.name }}" ENABLE ROW LEVEL SECURITY;

DROP POLICY IF EXISTS "{{ t.name }}_select_own" ON public."{{ t.name }}";
CREATE POLICY "{{ t.name }}_select_own" ON public."{{ t.name }}"
    AS PERMISSIVE FOR SELECT
    TO authenticated
    USING ((SELECT auth.uid()) = "user_id");

DROP POLICY IF EXISTS "{{ t.name }}_insert_own" ON public."{{ t.name }}";
CREATE POLICY "{{ t.name }}_insert_own" ON public."{{ t.name }}"
    AS PERMISSIVE FOR INSERT
    TO authenticated
    WITH CHECK ((SELECT auth.uid()) = "user_id");

DROP POLICY IF EXISTS "{{ t.name }}_update_own" ON public."{{ t.name }}";
CREATE POLICY "{{ t.name }}_update_own" ON public."{{ t.name }}"
    AS PERMISSIVE FOR UPDATE
    TO authenticated
    USING ((SELECT auth.uid()) = "user_id")
    WITH CHECK ((SELECT auth.uid()) = "user_id");

DROP POLICY IF EXISTS "{{ t.name }}_delete_own" ON public."{{ t.name }}";
CREATE POLICY "{{ t.name }}_delete_own" ON public."{{ t.name }}"
    AS PERMISSIVE FOR DELETE
    TO authenticated
    USING ((SELECT auth.uid()) = "user_id");

{% endfor %}
