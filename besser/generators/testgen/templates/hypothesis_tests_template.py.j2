@given(instance={{ constraint.context.name }}_strategy)
def test_{{ constraint.context.name | lower }}_ocl_{{ constraint.name | lower }}(instance):
     {# --- extract attributes used with @pre --- #}
    {# ---- get expression without the OCL header ---- #}
    {%- set expr = constraint.expression.split(':')[-1].strip() %}
    {# ---- detect @pre attributes ---- #}
    {%- set pres = expr | regex_findall('self\\.([a-zA-Z_][a-zA-Z0-9_]*)@pre') %}
    {%- for attr in pres %}
    before_{{ attr }} = instance.{{ attr }}
    {%- endfor %}
    {# ---- extract operation name ---- #}
    {%- set ctx = constraint.expression|string %}
    {%- set op_name = ctx.split('::')[1].split('(')[0] %}
    {# ---- extract parameter type from constraint expression ---- #}
    {%- set param_type = ctx.split('(')[1].split(')')[0].split(':')[-1].strip() | lower %}
    {# ---- declare parameter with correct type ---- #}
    {%- if param_type in ['integer', 'int'] %}
    value = 1
    {%- elif param_type in ['real', 'float', 'double'] %}
    value = 1.0
    {%- elif param_type in ['string', 'str'] %}
    value = "1"
    {%- elif param_type in ['bool', 'boolean'] %}
    value = True
    {%- else %}
    value = 1
    {%- endif %}
    # Call the operation
    instance.{{ op_name }}(value)
    {# --- replace all @pre references with before_ variables ---#}
    {%- for attr in pres %}
    {%- set expr = expr | replace('self.' ~ attr ~ '@pre', 'before_' ~ attr) %}
    {%- endfor %}
    {%- set expr = expr | regex_replace('self.(\\w+)@pre', 'before_\\1') %}
    {%- set expr = expr | regex_replace('self.', 'instance.') %}
    {%- set expr = expr | regex_replace('=', '==') %}
    assert {{ expr }}

