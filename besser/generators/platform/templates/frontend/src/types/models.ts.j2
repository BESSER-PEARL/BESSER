// ---------------------------------------------------------------------------
// Enumerations (enum-typed attributes render as dropdowns)
// ---------------------------------------------------------------------------
// Map each enumeration name to its allowed literal values. Keyed by the
// attribute's ``type`` string (the enumeration class name in the diagram).

export const ENUMERATIONS: Record<string, string[]> = {
  {%- for enum in enumerations %}
  '{{ enum.name }}': [{% for literal in enum.literals %}'{{ literal.name }}'{% if not loop.last %}, {% endif %}{% endfor %}]{% if not loop.last %},{% endif %}
  {%- endfor %}
};

/** Returns the literal values for an enumeration type, or null if not an enum. */
export function getEnumerationValues(typeName: string): string[] | null {
  return Object.prototype.hasOwnProperty.call(ENUMERATIONS, typeName)
    ? ENUMERATIONS[typeName]
    : null;
}

// ---------------------------------------------------------------------------
// Representation registries (port / connection classes resolved by name)
// ---------------------------------------------------------------------------
// Inheritance is resolved at generation time: a subclass of a flagged class
// is automatically present in these registries.

export const PORT_CLASSES: Record<string, PortClassMeta> = {
  {%- for name, info in port_classes_registry.items() %}
  '{{ name }}': { portSide: '{{ info.portSide or "auto" }}' }{% if not loop.last %},{% endif %}
  {%- endfor %}
};

export const CONNECTION_CLASSES: Record<string, ConnectionClassMeta> = {
  {%- for name, info in connection_classes_registry.items() %}
  '{{ name }}': {
    sourceAssociation: {% if info.sourceAssociation %}'{{ info.sourceAssociation }}'{% else %}null{% endif %},
    targetAssociation: {% if info.targetAssociation %}'{{ info.targetAssociation }}'{% else %}null{% endif %},
    portClass: {% if info.portClass %}'{{ info.portClass }}'{% else %}null{% endif %}
  }{% if not loop.last %},{% endif %}
  {%- endfor %}
};

/** Lookup helper: is this class (or one of its registered ancestors) a port class? */
export function isPortClass(className: string): boolean {
  return Object.prototype.hasOwnProperty.call(PORT_CLASSES, className);
}

/** Lookup helper: is this class a connection class? */
export function isConnectionClass(className: string): boolean {
  return Object.prototype.hasOwnProperty.call(CONNECTION_CLASSES, className);
}

// ---------------------------------------------------------------------------
// Subclass registry (polymorphic instance matching)
// ---------------------------------------------------------------------------
// Maps each class name to itself + all transitive subclasses, so the editor
// can treat a ``Compressor`` instance as an ``Equipment`` wherever the latter
// is expected (link target picker, connection-class port matching, etc.).

export const SUBCLASSES_OF: Record<string, string[]> = {
  {%- for parent_name, descendants in subclass_registry.items() %}
  '{{ parent_name }}': [{% for d in descendants %}'{{ d }}'{% if not loop.last %}, {% endif %}{% endfor %}]{% if not loop.last %},{% endif %}
  {%- endfor %}
};

/** Returns true when an instance of ``actualClass`` can stand in for an
 *  expected target typed as ``expectedClass``. Matches strict equality plus
 *  any transitive subclass. Falls back to strict equality for unknown
 *  classes (e.g. primitive types). */
export function isAssignableTo(actualClass: string, expectedClass: string): boolean {
  const list = SUBCLASSES_OF[expectedClass];
  if (list) return list.includes(actualClass);
  return actualClass === expectedClass;
}
