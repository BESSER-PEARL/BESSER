# Generated by BESSER DockerComposeGenerator from a UML Deployment model.
version: "3.9"

services:
{% for svc in services %}
  {{ svc.name }}:
{% if svc.stereotypes %}
    # stereotypes: {{ svc.stereotypes }}
{% endif %}
{% if svc.manifests %}
    # manifests: {{ svc.manifests }}
{% endif %}
{% if svc.build %}
    build: {{ svc.build }}
{% elif svc.is_hybrid %}
    image: {{ svc.image }}  # hybrid
{% else %}
    image: {{ svc.image }}
{% endif %}
{% if svc.networks %}
    networks: [{{ svc.networks | join(", ") }}]
{% endif %}
{% if svc.depends_on %}
    depends_on: [{{ svc.depends_on | join(", ") }}]
{% endif %}
{% if svc.replicas %}
    deploy:
      replicas: {{ svc.replicas }}
{% endif %}
{% endfor %}
{% if networks %}

networks:
{% for net in networks %}
  {{ net.name }}: {}{{ net.kind_comment }}
{% endfor %}
{% endif %}
